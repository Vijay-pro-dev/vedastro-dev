APP_NAME=Vedastro SaaS API
APP_ENV=development
DEBUG=true
SECRET_KEY=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_HOURS=12
DATABASE_URL=sqlite:///./storage/users.db
REDIS_URL=redis://redis:6379/0
USE_REDIS_RATE_LIMIT=false
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CORS_ALLOW_ORIGIN_REGEX=https?://(localhost|127\\.0\\.0\\.1)(:\\d+)?$
CORS_ALLOW_CREDENTIALS=true
UPLOADS_DIR=storage/uploads
MAX_UPLOAD_SIZE_BYTES=5242880
ALLOWED_UPLOAD_EXTENSIONS=.jpg,.jpeg,.png,.webp
AUTH_RATE_LIMIT_PER_MINUTE=12
GENERAL_RATE_LIMIT_PER_MINUTE=120
DEFAULT_ADMIN_EMAIL=admin@gmail.com
DEFAULT_ADMIN_PASSWORD=admin123
DEFAULT_ADMIN_NAME=Vedastro Admin
FRONTEND_BASE_URL=http://localhost:5173
EMAIL_FROM=no-reply@vedastro.local
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=omjig017@gmail.com
SMTP_PASSWORD=omjigupta@@
SMTP_USE_TLS=true
REQUEST_LOG_FILE=logs/backend.log
SECURITY_LOG_FILE=logs/backend.err.log
VITE_API_BASE_URL=http://127.0.0.1:8000

# For local workflows, prefer:
# - .env.dev for development
# - .env.prod for production
